---
import Layout from "../layouts/Layout.astro";
import Catalogo from "../components/Catalogo.astro";
import Contacto from "../components/Contacto.astro";
import { linkWhatsapp } from "../lib/utils";
import sitio from "../data/sitio.json";
import { categorias } from "../lib/categorias";
import { productos } from "../lib/productos";

const wa = linkWhatsapp(sitio.whatsapp, `¡Hola ${sitio.nombre}! Quería hacer una consulta 😊`);

const destacado =
  productos.find((p) => p.destacado && p.imagenes.length > 0) ??
  productos.find((p) => p.imagenes.length > 0);
const heroImg = destacado?.imagenes[0];

const pad = (n: number) => (n < 10 ? "0" + n : "" + n);
const cats = categorias.map((c, i) => ({
  ...c,
  num: pad(i + 1),
  count: productos.filter((p) => p.categoria === c.nombre).length,
}));
---

<Layout>
  <section class="hero">
    <div class="hero-inner container">
      <div class="hero-texto">
        <div class="hero-eyebrow">
          <span>Bazar &amp; Barismo</span>
          <span class="hero-line"></span>
        </div>
        <h1>Objetos para el ritual del <span class="italic">café y el té.</span></h1>
        <p class="hero-sub">
          Teteras, vasos y herramientas de barismo con diseño. Mirá el catálogo y escribinos
          por WhatsApp para comprar o consultar.
        </p>
        <div class="hero-cta">
          <a href="#catalogo" class="hero-btn-light">Ver catálogo</a>
          <a href={wa} target="_blank" rel="noopener" class="hero-btn-ghost">Consultar por WhatsApp</a>
        </div>
      </div>
      <div class="hero-foto">
        {heroImg ? (
          <img src={heroImg} alt={destacado?.nombre} />
        ) : (
          <span class="hero-foto-ph" aria-hidden="true">V</span>
        )}
      </div>
    </div>
  </section>

  <section id="categorias" class="categorias container">
    <div class="cat-head">
      <div>
        <p class="eyebrow">Explorá por tipo</p>
        <h2>Categorías</h2>
      </div>
      <span class="cat-head-meta">{pad(cats.length)} familias</span>
    </div>
    <div class="cat-grid">
      {cats.map((c) => (
        <a class="cat-card" href="#catalogo" data-cat={c.nombre}>
          <span class="cat-card-top">
            <span class="cat-card-num">/{c.num}</span>
            <span class="cat-card-arrow">→</span>
          </span>
          <span class="cat-card-bottom">
            <span class="cat-card-nombre">{c.nombre}</span>
            <span class="cat-card-count">{c.count > 0 ? `${c.count} productos` : "Próximamente"}</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <Catalogo productos={productos} categorias={categorias} />

  <Contacto />
</Layout>

<style>
  /* ===== HERO (oscuro) ===== */
  .hero {
    background: var(--hero-bg);
    color: #fff;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
    padding-block: clamp(48px, 6.5vw, 104px);
  }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 30px;
  }
  .hero-eyebrow span:first-child {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #837d73;
  }
  .hero-line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.14);
    max-width: 120px;
  }
  .hero-texto h1 {
    font-size: clamp(44px, 6.6vw, 92px);
    line-height: 1;
  }
  .hero-sub {
    margin-top: 30px;
    max-width: 430px;
    font-size: 15px;
    line-height: 1.72;
    color: #b3ada3;
  }
  .hero-cta {
    display: flex;
    gap: 12px;
    margin-top: 38px;
    flex-wrap: wrap;
  }
  .hero-btn-light {
    background: #fff;
    color: var(--ink);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 15px 30px;
    border-radius: 5px;
    transition: opacity 0.2s;
  }
  .hero-btn-light:hover {
    opacity: 0.85;
  }
  .hero-btn-ghost {
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 15px 26px;
    border-radius: 5px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    transition: border-color 0.2s;
  }
  .hero-btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.6);
  }
  .hero-foto {
    position: relative;
    overflow: hidden;
    background: var(--hero-surface);
    border-radius: 4px;
    aspect-ratio: 4 / 5;
    display: grid;
    place-items: center;
  }
  .hero-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .hero-foto:hover img {
    transform: scale(1.04);
  }
  .hero-foto-ph {
    font-family: var(--font-serif);
    font-size: 6rem;
    color: rgba(255, 255, 255, 0.2);
  }

  /* ===== CATEGORÍAS (grilla) ===== */
  .categorias {
    padding-block: clamp(56px, 7vw, 96px) clamp(36px, 4vw, 56px);
  }
  .cat-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 30px;
  }
  .cat-head h2 {
    margin-top: 16px;
    font-size: clamp(34px, 4.4vw, 54px);
  }
  .cat-head-meta {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }
  .cat-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 24px 22px;
    min-height: 158px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--ink);
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .cat-card:hover {
    border-color: var(--ink);
    transform: translateY(-3px);
  }
  .cat-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .cat-card-num {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--ink-faint-2);
  }
  .cat-card-arrow {
    font-size: 18px;
  }
  .cat-card-nombre {
    display: block;
    font-family: var(--font-serif);
    font-size: 30px;
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .cat-card-count {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-top: 9px;
  }

  @media (max-width: 820px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-foto {
      order: -1;
      aspect-ratio: 16 / 10;
    }
  }
</style>
