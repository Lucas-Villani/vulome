---
import Layout from "../layouts/Layout.astro";
import Catalogo from "../components/Catalogo.astro";
import Contacto from "../components/Contacto.astro";
import { linkWhatsapp } from "../lib/utils";
import sitio from "../data/sitio.json";
import { categorias } from "../lib/categorias";
import { productos } from "../lib/productos";

const wa = linkWhatsapp(sitio.whatsapp, `¡Hola ${sitio.nombre}! Quería hacer una consulta 😊`);

const destacado =
  productos.find((p) => p.destacado && p.imagenes.length > 0) ??
  productos.find((p) => p.imagenes.length > 0);
const heroImg = destacado?.imagenes[0];

const pad = (n: number) => (n < 10 ? "0" + n : "" + n);
const cats = categorias.map((c, i) => ({
  ...c,
  num: pad(i + 1),
  count: productos.filter((p) => p.categoria === c.nombre).length,
}));
---

<Layout>
  <section class="hero">
    <div class="hero-texto">
      <p class="eyebrow">Bazar &amp; Barismo</p>
      <h1>Objetos simples<br />para tu cocina<br />y tu <span>café.</span></h1>
      <p class="hero-sub">
        Seleccionamos teteras, vasos y herramientas de barismo con diseño. Mirá el catálogo
        y escribinos por WhatsApp para comprar o consultar.
      </p>
      <div class="hero-cta">
        <a href="#catalogo" class="btn-primary">Ver catálogo</a>
        <a href={wa} target="_blank" rel="noopener" class="btn-ghost">Consultar por WhatsApp</a>
      </div>
    </div>
    <div class="hero-foto">
      {heroImg ? (
        <img src={heroImg} alt={destacado?.nombre} />
      ) : (
        <span class="hero-foto-ph" aria-hidden="true">{sitio.nombre.charAt(0)}</span>
      )}
    </div>
  </section>

  <section id="categorias" class="categorias container">
    <div class="cat-head">
      <div>
        <p class="eyebrow">Explorá por tipo</p>
        <h2>Categorías</h2>
      </div>
      <p class="cat-head-nota">Cinco familias de productos, una misma búsqueda de calidad.</p>
    </div>
    <div class="cat-lista">
      {cats.map((c) => (
        <a class="cat-row" href="#catalogo" data-cat={c.nombre}>
          <span class="cat-row-left">
            <span class="cat-num">{c.num}</span>
            <span class="cat-nombre">{c.nombre}</span>
          </span>
          <span class="cat-row-right">
            <span class="cat-count">{c.count > 0 ? `${c.count} productos` : "Próximamente"}</span>
            <span class="cat-flecha">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <Catalogo productos={productos} categorias={categorias} />

  <Contacto />
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    display: grid;
    grid-template-columns: 1.04fr 1fr;
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(44px, 6.5vw, 96px) var(--pad) clamp(40px, 5vw, 68px);
  }
  .hero-texto h1 {
    margin-top: 26px;
    font-weight: 300;
    font-size: clamp(40px, 6.1vw, 82px);
    line-height: 1;
    letter-spacing: -0.028em;
  }
  .hero-texto h1 span {
    font-weight: 500;
  }
  .hero-sub {
    margin-top: 30px;
    max-width: 440px;
    font-size: 15.5px;
    line-height: 1.72;
    color: var(--ink-soft);
  }
  .hero-cta {
    display: flex;
    gap: 14px;
    margin-top: 38px;
    flex-wrap: wrap;
  }
  .hero-foto {
    position: relative;
    overflow: hidden;
    background: var(--surface);
    border-radius: var(--radius-sm);
    aspect-ratio: 4 / 5;
    display: grid;
    place-items: center;
  }
  .hero-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .hero-foto:hover img {
    transform: scale(1.04);
  }
  .hero-foto-ph {
    font-size: 5rem;
    font-weight: 300;
    color: var(--ink-faint);
  }

  /* ===== CATEGORÍAS (lista editorial) ===== */
  .categorias {
    padding-block: clamp(56px, 7vw, 96px) clamp(40px, 5vw, 64px);
  }
  .cat-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .cat-head h2 {
    margin-top: 14px;
    font-weight: 300;
    font-size: clamp(28px, 4vw, 46px);
    letter-spacing: -0.02em;
  }
  .cat-head-nota {
    font-size: 13px;
    color: var(--ink-mute);
    max-width: 280px;
    line-height: 1.6;
  }
  .cat-lista {
    margin-top: 30px;
    border-top: 1px solid var(--line-2);
  }
  .cat-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: clamp(18px, 2.4vw, 26px) clamp(8px, 1.5vw, 18px);
    border-bottom: 1px solid var(--line-2);
    color: var(--ink);
    transition: padding-left 0.3s var(--ease), background 0.3s var(--ease);
  }
  .cat-row:hover {
    padding-left: 26px;
    background: rgba(255, 255, 255, 0.6);
  }
  .cat-row-left {
    display: flex;
    align-items: baseline;
    gap: clamp(16px, 2.5vw, 34px);
    min-width: 0;
  }
  .cat-num {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--ink-faint-2);
    flex: none;
  }
  .cat-nombre {
    font-weight: 300;
    font-size: clamp(24px, 3.4vw, 42px);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .cat-row-right {
    display: flex;
    align-items: center;
    gap: clamp(16px, 2vw, 28px);
    flex: none;
  }
  .cat-count {
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--ink-mute);
    text-transform: uppercase;
  }
  .cat-flecha {
    font-size: 22px;
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-foto {
      order: -1;
      aspect-ratio: 16 / 10;
    }
  }
</style>
