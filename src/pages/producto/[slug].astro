---
import Layout from "../../layouts/Layout.astro";
import IconoWhatsapp from "../../components/IconoWhatsapp.astro";
import { productos } from "../../lib/productos";
import { formatearPrecio, linkWhatsapp, slugify } from "../../lib/utils";
import sitio from "../../data/sitio.json";

export function getStaticPaths() {
  return productos.map((p) => ({ params: { slug: p.slug }, props: { producto: p } }));
}

const { producto } = Astro.props;
const inicial = producto.nombre.charAt(0).toUpperCase();
const fotos = producto.imagenes ?? [];
const medidas = (producto.medidas ?? []).filter((m) => m && m.medida && m.precio);
const tieneMedidas = medidas.length > 0;
const catSlug = slugify(producto.categoria);
const wa = linkWhatsapp(
  sitio.whatsapp,
  `¡Hola ${sitio.nombre}! Me interesa este producto: ${producto.nombre}. ¿Está disponible?`
);
---

<Layout title={`${producto.nombre} — VULOME`} description={producto.descripcion}>
  <section class="detalle section">
    <div class="container">
      <nav class="crumbs">
        <a href="/">Inicio</a><span>/</span>
        <a href={`/categoria/${catSlug}`}>{producto.categoria}</a><span>/</span>
        <span class="current">{producto.nombre}</span>
      </nav>

      <div class="detalle-grid">
        <div class="galeria">
          {fotos.length > 0 ? (
            <div class="carrusel">
              <div class="carrusel-viewport">
                <img id="fotoPrincipal" src={fotos[0]} alt={producto.nombre} />
              </div>
              {fotos.length > 1 && (
                <div class="carrusel-controles">
                  <button class="flecha flecha-prev" id="flechaPrev" type="button" aria-label="Foto anterior">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m15 18-6-6 6-6"></path></svg>
                  </button>
                  <button class="flecha flecha-next" id="flechaNext" type="button" aria-label="Foto siguiente">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m9 18 6-6-6-6"></path></svg>
                  </button>
                  <div class="contador"><span id="contadorActual">1</span> / {fotos.length}</div>
                </div>
              )}
            </div>
          ) : (
            <div class="carrusel-viewport sin-foto"><span aria-hidden="true">{inicial}</span></div>
          )}

          {fotos.length > 1 && (
            <div class="miniaturas">
              {fotos.map((f, i) => (
                <button class={i === 0 ? "mini activa" : "mini"} data-index={i} type="button" aria-label={`Ver foto ${i + 1}`}>
                  <img src={f} alt={`${producto.nombre} ${i + 1}`} />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="detalle-info">
          <span class="cat">{producto.categoria}</span>
          <h1>{producto.nombre}</h1>

          {tieneMedidas ? (
            <div class="precios">
              {medidas.map((m) => (
                <div class="precio-row">
                  <span class="precio-medida">{m.medida}</span>
                  <strong class="precio-valor">{formatearPrecio(m.precio)}</strong>
                </div>
              ))}
            </div>
          ) : (
            <div class="precio-unico">{formatearPrecio(producto.precio)}</div>
          )}

          <p class="descripcion">{producto.descripcion}</p>

          <a class="btn-whatsapp" href={wa} target="_blank" rel="noopener">
            <IconoWhatsapp size={20} />
            Consultar por WhatsApp
          </a>
          <a class="volver" href="/#catalogo">← Volver al catálogo</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .crumbs {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin-bottom: 2rem;
  }
  .crumbs a:hover {
    color: var(--ink);
  }
  .crumbs .current {
    color: var(--ink);
  }
  .detalle-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
  }

  /* ===== Carrusel ===== */
  .carrusel {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
  }
  .carrusel-viewport {
    aspect-ratio: 1 / 1;
    background: var(--surface);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .carrusel-viewport img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
  }
  .carrusel-viewport.sin-foto {
    border-radius: var(--radius);
  }
  .carrusel-viewport.sin-foto span {
    font-size: 5rem;
    font-weight: 600;
    color: var(--ink-faint);
  }
  .flecha {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.92);
    color: var(--ink);
    display: grid;
    place-items: center;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.14);
    transition: background 0.2s, transform 0.2s;
  }
  .flecha:hover {
    background: #fff;
  }
  .flecha:active {
    transform: translateY(-50%) scale(0.92);
  }
  .flecha-prev {
    left: 0.8rem;
  }
  .flecha-next {
    right: 0.8rem;
  }
  .contador {
    position: absolute;
    bottom: 0.8rem;
    right: 0.8rem;
    background: rgba(17, 17, 16, 0.72);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.22rem 0.65rem;
    border-radius: 100px;
    backdrop-filter: blur(4px);
  }

  /* ===== Miniaturas ===== */
  .miniaturas {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.8rem;
    flex-wrap: wrap;
  }
  .mini {
    width: 66px;
    height: 66px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--surface);
    cursor: pointer;
    padding: 0;
    transition: border-color 0.2s;
  }
  .mini.activa {
    border-color: var(--ink);
  }
  .mini img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== Info ===== */
  .detalle-info .cat {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-faint);
  }
  .detalle-info h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin: 0.5rem 0 1.2rem;
  }
  .precios {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    max-width: 320px;
  }
  .precio-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--line);
  }
  .precio-medida {
    color: var(--ink-soft);
  }
  .precio-valor {
    font-size: 1.2rem;
    font-weight: 600;
  }
  .precio-unico {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .descripcion {
    color: var(--ink-soft);
    line-height: 1.65;
    margin: 1.4rem 0 2rem;
    white-space: pre-line;
  }
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--accent);
    color: var(--accent-ink);
    padding: 0.95rem 1.8rem;
    border-radius: 100px;
    font-weight: 500;
    transition: transform 0.2s, opacity 0.2s;
  }
  .btn-whatsapp:hover {
    transform: translateY(-2px);
    opacity: 0.92;
  }
  .volver {
    display: block;
    margin-top: 1.5rem;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }
  .volver:hover {
    color: var(--ink);
  }
  @media (max-width: 800px) {
    .detalle-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script define:vars={{ fotos }}>
  const principal = document.getElementById("fotoPrincipal");
  if (principal && fotos.length > 1) {
    const prev = document.getElementById("flechaPrev");
    const next = document.getElementById("flechaNext");
    const contador = document.getElementById("contadorActual");
    const minis = Array.from(document.querySelectorAll(".mini"));
    let actual = 0;

    function mostrar(i) {
      actual = (i + fotos.length) % fotos.length;
      principal.src = fotos[actual];
      if (contador) contador.textContent = String(actual + 1);
      minis.forEach((m, idx) => m.classList.toggle("activa", idx === actual));
    }

    if (prev) prev.addEventListener("click", () => mostrar(actual - 1));
    if (next) next.addEventListener("click", () => mostrar(actual + 1));
    minis.forEach((m, idx) => m.addEventListener("click", () => mostrar(idx)));

    document.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") mostrar(actual - 1);
      else if (e.key === "ArrowRight") mostrar(actual + 1);
    });

    const viewport = document.querySelector(".carrusel-viewport");
    let x0 = null;
    if (viewport) {
      viewport.addEventListener("touchstart", (e) => { x0 = e.touches[0].clientX; }, { passive: true });
      viewport.addEventListener("touchend", (e) => {
        if (x0 === null) return;
        const dx = e.changedTouches[0].clientX - x0;
        if (Math.abs(dx) > 40) mostrar(actual + (dx < 0 ? 1 : -1));
        x0 = null;
      }, { passive: true });
    }
  }
</script>
