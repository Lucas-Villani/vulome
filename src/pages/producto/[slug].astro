---
import Layout from "../../layouts/Layout.astro";
import IconoWhatsapp from "../../components/IconoWhatsapp.astro";
import { productos } from "../../lib/productos";
import { formatearPrecio, linkWhatsapp, slugify } from "../../lib/utils";
import sitio from "../../data/sitio.json";

export function getStaticPaths() {
  return productos.map((p) => ({ params: { slug: p.slug }, props: { producto: p } }));
}

const { producto } = Astro.props;
const inicial = producto.nombre.charAt(0).toUpperCase();
const fotos = producto.imagenes ?? [];
const medidas = (producto.medidas ?? []).filter((m) => m && m.medida && m.precio);
const tieneMedidas = medidas.length > 0;
const catSlug = slugify(producto.categoria);
const wa = linkWhatsapp(
  sitio.whatsapp,
  `¡Hola ${sitio.nombre}! Me interesa este producto: ${producto.nombre}. ¿Está disponible?`
);
---

<Layout title={`${producto.nombre} — VULOME`} description={producto.descripcion}>
  <section class="detalle section">
    <div class="container">
      <nav class="crumbs">
        <a href="/">Inicio</a><span>/</span>
        <a href={`/categoria/${catSlug}`}>{producto.categoria}</a><span>/</span>
        <span class="current">{producto.nombre}</span>
      </nav>

      <div class="detalle-grid">
        <div class="galeria">
          {fotos.length > 0 ? (
            <div class="foto-principal">
              <img id="fotoPrincipal" src={fotos[0]} alt={producto.nombre} />
            </div>
          ) : (
            <div class="foto-principal sin-foto"><span aria-hidden="true">{inicial}</span></div>
          )}
          {fotos.length > 1 && (
            <div class="miniaturas">
              {fotos.map((f, i) => (
                <button class={i === 0 ? "mini activa" : "mini"} data-foto={f} type="button" aria-label={`Foto ${i + 1}`}>
                  <img src={f} alt={`${producto.nombre} ${i + 1}`} />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="detalle-info">
          <span class="cat">{producto.categoria}</span>
          <h1>{producto.nombre}</h1>

          {tieneMedidas ? (
            <div class="precios">
              {medidas.map((m) => (
                <div class="precio-row">
                  <span class="precio-medida">{m.medida}</span>
                  <strong class="precio-valor">{formatearPrecio(m.precio)}</strong>
                </div>
              ))}
            </div>
          ) : (
            <div class="precio-unico">{formatearPrecio(producto.precio)}</div>
          )}

          <p class="descripcion">{producto.descripcion}</p>

          <a class="btn-whatsapp" href={wa} target="_blank" rel="noopener">
            <IconoWhatsapp size={20} />
            Consultar por WhatsApp
          </a>
          <a class="volver" href="/#catalogo">← Volver al catálogo</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .crumbs {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin-bottom: 2rem;
  }
  .crumbs a:hover {
    color: var(--ink);
  }
  .crumbs .current {
    color: var(--ink);
  }
  .detalle-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
  }
  .foto-principal {
    aspect-ratio: 1 / 1;
    background: var(--surface);
    border-radius: var(--radius);
    overflow: hidden;
    display: grid;
    place-items: center;
  }
  .foto-principal img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .foto-principal.sin-foto span {
    font-size: 5rem;
    font-weight: 600;
    color: var(--ink-faint);
  }
  .miniaturas {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.8rem;
    flex-wrap: wrap;
  }
  .mini {
    width: 66px;
    height: 66px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--surface);
    cursor: pointer;
    padding: 0;
    transition: border-color 0.2s;
  }
  .mini.activa {
    border-color: var(--ink);
  }
  .mini img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .detalle-info .cat {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-faint);
  }
  .detalle-info h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin: 0.5rem 0 1.2rem;
  }
  .precios {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    max-width: 320px;
  }
  .precio-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--line);
  }
  .precio-medida {
    color: var(--ink-soft);
  }
  .precio-valor {
    font-size: 1.2rem;
    font-weight: 600;
  }
  .precio-unico {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .descripcion {
    color: var(--ink-soft);
    line-height: 1.65;
    margin: 1.4rem 0 2rem;
  }
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--accent);
    color: var(--accent-ink);
    padding: 0.95rem 1.8rem;
    border-radius: 100px;
    font-weight: 500;
    transition: transform 0.2s, opacity 0.2s;
  }
  .btn-whatsapp:hover {
    transform: translateY(-2px);
    opacity: 0.92;
  }
  .volver {
    display: block;
    margin-top: 1.5rem;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }
  .volver:hover {
    color: var(--ink);
  }
  @media (max-width: 800px) {
    .detalle-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const principal = document.getElementById("fotoPrincipal") as HTMLImageElement | null;
  const minis = document.querySelectorAll<HTMLButtonElement>(".mini");
  minis.forEach((btn) => {
    btn.addEventListener("click", () => {
      const f = btn.getAttribute("data-foto");
      if (principal && f) principal.src = f;
      minis.forEach((b) => b.classList.remove("activa"));
      btn.classList.add("activa");
    });
  });
</script>
