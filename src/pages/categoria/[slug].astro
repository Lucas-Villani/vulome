---
import Layout from "../../layouts/Layout.astro";
import ProductoCard from "../../components/ProductoCard.astro";
import { categorias } from "../../lib/categorias";
import { productos } from "../../lib/productos";

export function getStaticPaths() {
  return categorias.map((c) => ({
    params: { slug: c.slug },
    props: { categoria: c, items: productos.filter((p) => p.categoria === c.nombre) },
  }));
}

const { categoria, items } = Astro.props;
---

<Layout title={`${categoria.nombre} — VULOME`} description={categoria.descripcion}>
  <section class="cat-page container">
    <nav class="crumbs">
      <a href="/">Inicio</a><span>/</span><span class="current">{categoria.nombre}</span>
    </nav>
    <p class="eyebrow">Categoría</p>
    <h1>{categoria.nombre}</h1>
    <p class="lead">{categoria.descripcion}</p>

    {items.length > 0 ? (
      <div class="grid-productos">
        {items.map((p) => <ProductoCard producto={p} />)}
      </div>
    ) : (
      <p class="empty">Pronto vamos a sumar productos a esta categoría.</p>
    )}
  </section>
</Layout>

<style>
  .cat-page {
    padding-block: clamp(28px, 3.5vw, 44px) clamp(64px, 8vw, 110px);
  }
  .crumbs {
    display: flex;
    gap: 9px;
    align-items: center;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--ink-faint);
    margin-bottom: clamp(20px, 2.5vw, 32px);
  }
  .crumbs a {
    color: var(--ink-mute);
    transition: color 0.2s;
  }
  .crumbs a:hover {
    color: var(--ink);
  }
  .crumbs .current {
    color: var(--ink);
    font-weight: 500;
  }
  .cat-page h1 {
    margin-top: 14px;
    font-weight: 300;
    font-size: clamp(34px, 5vw, 58px);
    letter-spacing: -0.025em;
  }
  .lead {
    margin-top: 0.8rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    color: var(--ink-mute);
    font-size: 1rem;
    max-width: 50ch;
  }
  .empty {
    color: var(--ink-mute);
    padding: 3rem 0;
  }
</style>
