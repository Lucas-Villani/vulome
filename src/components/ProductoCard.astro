---
import { formatearPrecio, linkWhatsapp } from "../lib/utils";
import IconoWhatsapp from "./IconoWhatsapp.astro";
import sitio from "../data/sitio.json";
import type { Producto } from "../lib/productos";

const { producto } = Astro.props as { producto: Producto };
const inicial = producto.nombre.charAt(0).toUpperCase();
const foto = producto.imagenes[0] ?? "";
const medidas = (producto.medidas ?? []).filter((m) => m && m.medida && m.precio);
const tieneMedidas = medidas.length > 0;
const url = `/producto/${producto.slug}`;
const wa = linkWhatsapp(
  sitio.whatsapp,
  `¡Hola ${sitio.nombre}! Me interesa este producto: ${producto.nombre}. ¿Está disponible?`
);
---

<article
  class="card"
  data-categoria={producto.categoria}
  data-nombre={producto.nombre.toLowerCase()}
>
  <a class="thumb" href={url} aria-label={producto.nombre}>
    {foto ? (
      <img src={foto} alt={producto.nombre} loading="lazy" />
    ) : (
      <span class="thumb-ph" aria-hidden="true">{inicial}</span>
    )}
    {producto.imagenes.length > 1 && (
      <span class="badge-fotos">{producto.imagenes.length} fotos</span>
    )}
  </a>
  <div class="info">
    <span class="cat">{producto.categoria}</span>
    <a class="nombre-link" href={url}><h3 class="nombre">{producto.nombre}</h3></a>
    <p class="desc">{producto.descripcion}</p>

    {tieneMedidas ? (
      <div class="medidas">
        {medidas.map((m) => (
          <div class="medida-row">
            <span class="medida-nombre">{m.medida}</span>
            <span class="medida-precio">{formatearPrecio(m.precio)}</span>
          </div>
        ))}
      </div>
    ) : (
      <div class="bottom">
        <span class="precio">{formatearPrecio(producto.precio)}</span>
      </div>
    )}

    <a class="btn-comprar" href={wa} target="_blank" rel="noopener">
      <IconoWhatsapp size={17} />
      Consultar por WhatsApp
    </a>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: transparent;
  }
  .thumb {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1 / 1;
    background: var(--surface);
    overflow: hidden;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease);
  }
  .card:hover .thumb img {
    transform: scale(1.04);
  }
  .thumb-ph {
    font-size: 3.5rem;
    font-weight: 600;
    color: var(--ink-faint);
    letter-spacing: -0.03em;
  }
  .badge-fotos {
    position: absolute;
    bottom: 0.6rem;
    right: 0.6rem;
    background: rgba(17, 17, 16, 0.78);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
    backdrop-filter: blur(4px);
  }
  .info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.1rem 1.1rem;
    flex: 1;
  }
  .cat {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-faint);
  }
  .nombre-link {
    text-decoration: none;
  }
  .nombre {
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.25;
    transition: color 0.2s;
  }
  .nombre-link:hover .nombre {
    color: var(--ink-soft);
  }
  .desc {
    font-size: 0.83rem;
    color: var(--ink-soft);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bottom {
    margin-top: 0.4rem;
  }
  .precio {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .medidas {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 0.5rem;
    padding: 0.6rem 0.75rem;
    background: var(--surface);
    border-radius: var(--radius-sm);
  }
  .medida-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 0.9rem;
  }
  .medida-nombre {
    color: var(--ink-soft);
  }
  .medida-precio {
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .btn-comprar {
    margin-top: 0.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    text-align: center;
    background: var(--accent);
    color: var(--accent-ink);
    padding: 0.7rem 1rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-comprar:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
