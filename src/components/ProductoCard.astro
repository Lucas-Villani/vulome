---
import { formatearPrecio } from "../lib/utils";
import type { Producto } from "../lib/productos";

const { producto } = Astro.props as { producto: Producto };
const inicial = producto.nombre.charAt(0).toUpperCase();
const foto = producto.imagenes[0] ?? "";
const medidas = (producto.medidas ?? []).filter((m) => m && m.medida && m.precio);
const tieneMedidas = medidas.length > 0;
const url = `/producto/${producto.slug}`;

let precioLabel: string;
if (tieneMedidas) {
  const precios = medidas.map((m) => m.precio);
  const min = Math.min(...precios);
  const max = Math.max(...precios);
  precioLabel = min === max ? formatearPrecio(min) : `${formatearPrecio(min)} – ${formatearPrecio(max)}`;
} else {
  precioLabel = formatearPrecio(producto.precio);
}
---

<a
  class="card"
  href={url}
  data-categoria={producto.categoria}
  data-nombre={producto.nombre.toLowerCase()}
>
  <div class="thumb">
    {foto ? (
      <img src={foto} alt={producto.nombre} loading="lazy" />
    ) : (
      <span class="thumb-ph" aria-hidden="true">{inicial}</span>
    )}
    {producto.imagenes.length > 1 && (
      <span class="badge-fotos">{producto.imagenes.length} fotos</span>
    )}
  </div>
  <div class="info">
    <div class="info-top">
      <span class="cat">{producto.categoria}</span>
      <h3 class="nombre">{producto.nombre}</h3>
      <p class="nota">{producto.descripcion}</p>
      {tieneMedidas && (
        <div class="chips">
          {medidas.map((m) => <span class="chip">{m.medida}</span>)}
        </div>
      )}
    </div>
    <div class="pie">
      <span class="precio">{precioLabel}</span>
      <span class="ver">Ver producto <span class="ver-flecha">→</span></span>
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #fffdfa;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 13px;
    color: var(--ink);
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease), border-color 0.3s;
  }
  .card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow);
    border-color: var(--line-2);
  }
  .thumb {
    position: relative;
    overflow: hidden;
    background: var(--surface);
    border-radius: 7px;
    aspect-ratio: 4 / 5;
    display: grid;
    place-items: center;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .card:hover .thumb img {
    transform: scale(1.05);
  }
  .thumb-ph {
    font-size: 3rem;
    font-weight: 300;
    color: var(--ink-faint);
  }
  .badge-fotos {
    position: absolute;
    bottom: 0.6rem;
    right: 0.6rem;
    background: rgba(20, 17, 15, 0.78);
    color: #fff;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 4px 10px;
    border-radius: 999px;
  }
  .info {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 15px 3px 3px;
  }
  .info-top {
    flex: 1;
  }
  .cat {
    display: block;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 9px;
  }
  .nombre {
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .nota {
    font-size: 13px;
    color: var(--ink-mute);
    line-height: 1.5;
    margin-top: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.9em;
  }
  .chips {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 12px;
  }
  .chip {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    border: 1px solid var(--line-2);
    padding: 5px 10px;
    border-radius: 999px;
  }
  .pie {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }
  .precio {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .ver {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--ink);
    white-space: nowrap;
  }
  .ver-flecha {
    font-size: 14px;
    transition: transform 0.25s var(--ease);
  }
  .card:hover .ver-flecha {
    transform: translateX(4px);
  }
</style>
