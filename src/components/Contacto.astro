---
import sitio from "../data/sitio.json";
import { linkWhatsapp } from "../lib/utils";

const wa = linkWhatsapp(sitio.whatsapp, `¡Hola ${sitio.nombre}! Quería hacer una consulta 😊`);
const ig = sitio.instagram ? `https://instagram.com/${sitio.instagram}` : null;
---

<section id="contacto" class="contacto">
  <div class="contacto-inner container">
    <div class="contacto-texto">
      <p class="eyebrow contacto-eyebrow">Hacé tu pedido</p>
      <h2>¿Te gustó algo?<br /><strong>Escribinos.</strong></h2>
      <p class="contacto-sub">
        Consultá disponibilidad, precios y envíos por WhatsApp. Respondemos a la brevedad.
      </p>
    </div>
    <div class="contacto-acciones">
      <a class="accion accion-wpp" href={wa} target="_blank" rel="noopener">
        <span class="accion-info">
          <span class="accion-label">WhatsApp</span>
          <span class="accion-valor">Iniciar conversación</span>
        </span>
        <span class="accion-flecha" aria-hidden="true">→</span>
      </a>
      {ig && (
        <a class="accion accion-ig" href={ig} target="_blank" rel="noopener">
          <span class="accion-info">
            <span class="accion-label">Instagram</span>
            <span class="accion-valor">@{sitio.instagram}</span>
          </span>
          <span class="accion-flecha" aria-hidden="true">→</span>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .contacto {
    background: #14110f;
    color: #fff;
  }
  .contacto-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(32px, 6vw, 80px);
    align-items: center;
    padding-block: clamp(64px, 9vw, 128px);
  }
  .contacto-eyebrow {
    color: #837d73;
  }
  .contacto-texto h2 {
    margin-top: 24px;
    font-weight: 300;
    font-size: clamp(32px, 5vw, 62px);
    line-height: 1.05;
    letter-spacing: -0.025em;
  }
  .contacto-texto h2 strong {
    font-weight: 500;
  }
  .contacto-sub {
    margin-top: 26px;
    max-width: 440px;
    font-size: 15px;
    line-height: 1.7;
    color: #b8b2a8;
  }
  .contacto-acciones {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .accion {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 22px 26px;
    border-radius: 14px;
    transition: transform 0.25s var(--ease), border-color 0.25s;
  }
  .accion-wpp {
    background: #fff;
    color: #14110f;
  }
  .accion-wpp:hover {
    transform: translateY(-3px);
  }
  .accion-ig {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
  }
  .accion-ig:hover {
    border-color: rgba(255, 255, 255, 0.55);
    transform: translateY(-3px);
  }
  .accion-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .accion-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.55;
  }
  .accion-valor {
    font-size: 18px;
    font-weight: 500;
  }
  .accion-flecha {
    font-size: 22px;
  }
  @media (max-width: 820px) {
    .contacto-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
