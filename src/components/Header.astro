---
import sitio from "../data/sitio.json";
import { linkWhatsapp } from "../lib/utils";

const wa = linkWhatsapp(sitio.whatsapp, `¡Hola ${sitio.nombre}! Quería hacer una consulta 😊`);
---

<header class="site-header">
  <div class="header-inner container">
    <a href="/" class="logo" aria-label={`${sitio.nombre} inicio`}>{sitio.nombre}</a>
    <nav class="nav">
      <a href="/#categorias" class="nav-link">Categorías</a>
      <a href="/#catalogo" class="nav-link">Catálogo</a>
      <a href="/#contacto" class="nav-link">Contacto</a>
      <a href={wa} target="_blank" rel="noopener" class="nav-wpp">WhatsApp</a>
    </nav>
    <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="nav-mobile" id="navMobile">
    <a href="/#categorias">Categorías</a>
    <a href="/#catalogo">Catálogo</a>
    <a href="/#contacto">Contacto</a>
    <a href={wa} target="_blank" rel="noopener">WhatsApp</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(246, 244, 240, 0.82);
    backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 17px;
  }
  .logo {
    font-weight: 600;
    font-size: 18px;
    letter-spacing: 0.42em;
    padding-left: 0.42em;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: clamp(16px, 3vw, 38px);
  }
  .nav-link {
    color: var(--ink-mute);
    font-size: 12.5px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .nav-link:hover {
    color: var(--ink);
  }
  .nav-wpp {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ink);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 11px 18px;
    border-radius: 999px;
    transition: opacity 0.2s;
  }
  .nav-wpp:hover {
    opacity: 0.78;
  }
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .menu-toggle span {
    display: block;
    height: 1.5px;
    width: 20px;
    margin-inline: auto;
    background: var(--ink);
  }
  .nav-mobile {
    display: none;
    flex-direction: column;
    border-top: 1px solid var(--line);
    padding: 0.5rem var(--pad) 1.2rem;
  }
  .nav-mobile a {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
    font-size: 1rem;
    color: var(--ink);
  }
  .nav-mobile.open {
    display: flex;
  }

  @media (max-width: 760px) {
    .nav {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById("menuToggle");
  const nav = document.getElementById("navMobile");
  toggle?.addEventListener("click", () => {
    const open = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!open));
  });
  nav?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => nav.classList.remove("open"))
  );
</script>
