---
import sitio from "../data/sitio.json";
import categorias from "../data/categorias.json";
import { linkWhatsapp } from "../lib/utils";
import IconoWhatsapp from "./IconoWhatsapp.astro";

const wa = linkWhatsapp(sitio.whatsapp, `¡Hola ${sitio.nombre}! Quería hacer una consulta 😊`);
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label={`${sitio.nombre} inicio`}>{sitio.nombre}</a>

    <nav class="nav" id="nav">
      {categorias.map((c) => <a href={`/categoria/${c.slug}`} class="nav-link">{c.nombre}</a>)}
    </nav>

    <div class="header-actions">
      <a href={wa} target="_blank" rel="noopener" class="wa-link">
        <IconoWhatsapp size={16} />
        WhatsApp
      </a>
      <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 64px;
  }
  .logo {
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.22em;
  }
  .nav {
    display: flex;
    gap: 1.5rem;
    margin-inline: auto;
  }
  .nav-link {
    font-size: 0.9rem;
    color: var(--ink-soft);
    transition: color 0.2s;
  }
  .nav-link:hover {
    color: var(--ink);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .wa-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.5rem 0.95rem;
    border: 1px solid var(--line);
    border-radius: 100px;
    transition: background 0.2s, border-color 0.2s;
  }
  .wa-link:hover {
    background: var(--surface);
    border-color: var(--ink-faint);
  }
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .menu-toggle span {
    display: block;
    height: 1.5px;
    width: 20px;
    margin-inline: auto;
    background: var(--ink);
  }

  @media (max-width: 820px) {
    .menu-toggle {
      display: flex;
    }
    .nav {
      position: fixed;
      inset: 64px 0 auto 0;
      flex-direction: column;
      gap: 0;
      margin: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--line);
      padding: 0.5rem var(--pad) 1.5rem;
      transform: translateY(-130%);
      transition: transform 0.3s var(--ease);
    }
    .nav.open {
      transform: translateY(0);
    }
    .nav-link {
      padding: 0.9rem 0;
      border-bottom: 1px solid var(--line);
      font-size: 1rem;
    }
    .wa-link {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById("menuToggle");
  const nav = document.getElementById("nav");
  toggle?.addEventListener("click", () => {
    const open = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!open));
  });
  nav?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => nav.classList.remove("open"))
  );
</script>
