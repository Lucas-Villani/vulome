---
import sitio from "../data/sitio.json";

const anio = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner container">
    <span class="footer-logo">{sitio.nombre}</span>
    <span class="footer-meta">{sitio.tagline} · Catálogo {anio}</span>
  </div>
</footer>

<style>
  .site-footer {
    background: #14110f;
    color: #837d73;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
    padding-block: 30px;
  }
  .footer-logo {
    color: #fff;
    font-weight: 600;
    letter-spacing: 0.42em;
    font-size: 14px;
    padding-left: 0.42em;
  }
  .footer-meta {
    font-size: 12px;
    letter-spacing: 0.04em;
  }
</style>
