---
import sitio from "../data/sitio.json";
import { linkWhatsapp } from "../lib/utils";

const anio = new Date().getFullYear();
const wa = linkWhatsapp(sitio.whatsapp, `¡Hola ${sitio.nombre}! Quería hacer una consulta 😊`);
const instagram = sitio.instagram;
const ig = instagram ? `https://instagram.com/${instagram}` : null;
---

<footer class="site-footer">
  <div class="container footer-cta">
    <div class="footer-texto">
      <p class="eyebrow">Hacé tu pedido</p>
      <h2>¿Te gustó algo?<br /><strong>Escribinos.</strong></h2>
      <p class="footer-sub">
        Consultá disponibilidad, precios y envíos por WhatsApp. Respondemos a la brevedad.
      </p>
    </div>

    <div class="footer-acciones">
      <a class="accion accion-wpp" href={wa} target="_blank" rel="noopener">
        <span class="accion-info">
          <span class="accion-label">WhatsApp</span>
          <span class="accion-valor">Iniciar conversación</span>
        </span>
        <span class="accion-flecha" aria-hidden="true">→</span>
      </a>
      {ig && (
        <a class="accion accion-ig" href={ig} target="_blank" rel="noopener">
          <span class="accion-info">
            <span class="accion-label">Instagram</span>
            <span class="accion-valor">@{instagram}</span>
          </span>
          <span class="accion-flecha" aria-hidden="true">→</span>
        </a>
      )}
    </div>
  </div>

  <div class="container footer-bottom">
    <span class="footer-logo">{sitio.nombre}</span>
    <span class="footer-meta">{sitio.tagline} · Catálogo {anio}</span>
  </div>
</footer>

<style>
  .site-footer {
    background: #100f0e;
    color: #fff;
    margin-top: clamp(4rem, 8vw, 7rem);
  }
  .footer-cta {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }
  .footer-texto .eyebrow {
    color: rgba(255, 255, 255, 0.4);
  }
  .footer-texto h2 {
    font-size: clamp(2.1rem, 5vw, 3.6rem);
    font-weight: 400;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin: 1rem 0 1.4rem;
    color: #fff;
  }
  .footer-texto h2 strong {
    font-weight: 700;
  }
  .footer-sub {
    color: rgba(255, 255, 255, 0.55);
    max-width: 42ch;
    font-size: 1rem;
    line-height: 1.6;
  }
  .footer-acciones {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .accion {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.6rem;
    border-radius: 16px;
    transition: transform 0.25s var(--ease), background 0.25s, border-color 0.25s;
  }
  .accion-wpp {
    background: #fff;
    color: #100f0e;
  }
  .accion-wpp:hover {
    transform: translateY(-3px);
  }
  .accion-ig {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: #fff;
  }
  .accion-ig:hover {
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-3px);
  }
  .accion-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .accion-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    opacity: 0.5;
  }
  .accion-valor {
    font-size: 1.15rem;
    font-weight: 500;
  }
  .accion-flecha {
    font-size: 1.25rem;
    transition: transform 0.25s var(--ease);
  }
  .accion:hover .accion-flecha {
    transform: translateX(5px);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .footer-logo {
    font-family: var(--font-titulo);
    font-weight: 700;
    letter-spacing: 0.18em;
    font-size: 1.1rem;
    color: #fff;
  }
  .footer-meta {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8rem;
  }
  @media (max-width: 820px) {
    .footer-cta {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
